     }
 }
 
diff --git a/omi/firmware/devkit/src/transport.c b/omi/firmware/devkit/src/transport.c
index b970ce2..d3ee60b 100644
--- a/omi/firmware/devkit/src/transport.c
+++ b/omi/firmware/devkit/src/transport.c
@@ -914,7 +914,11 @@ int broadcast_audio_packets(uint8_t *buffer, size_t size)
     }
 
     if (retry_count >= max_retries) {
-        LOG_ERR("Failed to write to tx queue after %d retries", max_retries);
+        /* Bring-up debug 2026-04-30: this fires every audio frame (~50 fps)
+         * when there is no consumer (no BLE conn, no SD on) so the queue
+         * stays full. The log storm starves CDC ACM / log workers and
+         * ultimately misses watchdog_feed. Demote to LOG_DBG. */
+        LOG_DBG("write_to_tx_queue failed after %d retries", max_retries);
         return -1;
     }
 
