diff --git a/omi/firmware/devkit/src/main.c b/omi/firmware/devkit/src/main.c
index 7679e1d..f1832d8 100644
--- a/omi/firmware/devkit/src/main.c
+++ b/omi/firmware/devkit/src/main.c
@@ -28,7 +28,9 @@ static void codec_handler(uint8_t *data, size_t len)
 {
     int err = broadcast_audio_packets(data, len);
     if (err) {
-        LOG_ERR("Failed to broadcast audio packets: %d", err);
+        /* Bring-up debug 2026-04-30: at 50 fps audio with no consumer
