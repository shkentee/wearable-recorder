diff --git a/omi/firmware/devkit/src/mic.c b/omi/firmware/devkit/src/mic.c
index 4dd0720..e665dfd 100644
--- a/omi/firmware/devkit/src/mic.c
+++ b/omi/firmware/devkit/src/mic.c
@@ -22,6 +22,29 @@ static int16_t _buffer_0[MIC_BUFFER_SAMPLES];
 static int16_t _buffer_1[MIC_BUFFER_SAMPLES];
 static volatile uint8_t _next_buffer_index = 0;
 static volatile mix_handler _callback = NULL;
+static uint8_t _mic_gain_level = 6;
+static bool _pdm_started = false;
+
+static uint8_t mic_gain_hw_value(uint8_t gain_level)
+{
+    static const uint8_t gain_map[9] = {
+        0x00, // Level 0: mute
+        0x14, // Level 1: -20dB
+        0x1E, // Level 2: -10dB
+        0x28, // Level 3: +0dB
+        0x2E, // Level 4: +6dB
+        0x32, // Level 5: +10dB
+        0x3C, // Level 6: +20dB (Omi default)
+        0x46, // Level 7: +30dB
+        0x50, // Level 8: +40dB
+    };
+
+    if (gain_level > 8) {
+        gain_level = 8;
+    }
+
+    return gain_map[gain_level];
+}
 
 static void pdm_irq_handler(nrfx_pdm_evt_t const *event)
 {
@@ -62,8 +85,9 @@ int mic_start()
 
     // Configure PDM
     nrfx_pdm_config_t pdm_config = NRFX_PDM_DEFAULT_CONFIG(PDM_CLK_PIN, PDM_DIN_PIN);
-    pdm_config.gain_l = MIC_GAIN;
-    pdm_config.gain_r = MIC_GAIN;
+    uint8_t mic_gain = mic_gain_hw_value(_mic_gain_level);
+    pdm_config.gain_l = mic_gain;
+    pdm_config.gain_r = mic_gain;
     pdm_config.interrupt_priority = MIC_IRC_PRIORITY;
     pdm_config.clock_freq = NRF_PDM_FREQ_1280K;
     pdm_config.mode = NRF_PDM_MODE_MONO;
@@ -85,6 +109,7 @@ int mic_start()
         return -1;
     }
 
+    _pdm_started = true;
     LOG_INF("Audio microphone started");
     return 0;
 }
@@ -94,6 +119,25 @@ void set_mic_callback(mix_handler callback)
     _callback = callback;
 }
 
+uint8_t mic_get_gain_level()
+{
+    return _mic_gain_level;
+}
+
+void mic_set_gain(uint8_t gain_level)
+{
+    if (gain_level > 8) {
+        gain_level = 8;
+    }
+
+    _mic_gain_level = gain_level;
+    uint8_t hw_gain = mic_gain_hw_value(gain_level);
+    if (_pdm_started) {
+        nrfy_pdm_gain_set(NRF_PDM, hw_gain, hw_gain);
+    }
+    LOG_INF("Audio mic gain set to level %u (0x%02x)", gain_level, hw_gain);
+}
+
 void mic_off()
 {
     nrfy_gpio_pin_clear(PDM_PWR_PIN);
