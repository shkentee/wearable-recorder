diff --git a/omi/firmware/devkit/overlay/xiao_ble_sense_devkitv1-spisd.overlay b/omi/firmware/devkit/overlay/xiao_ble_sense_devkitv1-spisd.overlay
index 06ac174..1af28dd 100644
--- a/omi/firmware/devkit/overlay/xiao_ble_sense_devkitv1-spisd.overlay
+++ b/omi/firmware/devkit/overlay/xiao_ble_sense_devkitv1-spisd.overlay
@@ -3,7 +3,7 @@
     pinctrl-0 = <&custom_spi>;
     pinctrl-1 = <&custom_spi>;
     pinctrl-names = "default", "sleep";
-    cs-gpios = <&gpio0 28 GPIO_ACTIVE_LOW>;  // CS pin on P0.28
+    cs-gpios = <&gpio1 13 GPIO_ACTIVE_LOW>;  // patch 0018: CS on D8 = P1.13 (was P0.28)
     sdhc0: sdhc@0 {
         compatible = "zephyr,sdhc-spi-slot";
         reg = <0>;
@@ -19,9 +19,15 @@
 &pinctrl {
     custom_spi: custom_spi {
         group1 {
-            psels = <NRF_PSEL(SPIM_SCK, 1, 13)>,  // SCK on P1.13
-                    <NRF_PSEL(SPIM_MOSI, 1, 15)>, // MOSI on P1.15
-                    <NRF_PSEL(SPIM_MISO, 1, 14)>; // MISO on P1.14
+            // patch 0018: pin map matched to actual hand-wired SD breakout.
+            // Physical wiring (confirmed by user 2026-05-01):
+            //   D2  (P0.28) -> SCK
+            //   D8  (P1.13) -> CS   (handled in cs-gpios above)
+            //   D9  (P1.14) -> MOSI
+            //   D10 (P1.15) -> MISO
+            psels = <NRF_PSEL(SPIM_SCK,  0, 28)>,  // SCK on D2 = P0.28
+                    <NRF_PSEL(SPIM_MOSI, 1, 14)>,  // MOSI on D9 = P1.14
+                    <NRF_PSEL(SPIM_MISO, 1, 15)>;  // MISO on D10 = P1.15
         };
     };
 };
