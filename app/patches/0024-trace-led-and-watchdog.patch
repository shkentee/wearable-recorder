From: knsol <noreply@anthropic.com>
Subject: [PATCH] debug: WR_TRACE around led_start, watchdog_init, etc

Disabling USB MSC (commit 19e1560) advanced main past 2_qspi_done.
Now hangs between 2_qspi_done and 3_pre_led_seq. Suspects: the
LOG_INF("Initializing LEDs...\n") between, or led_start() itself.

Replace the LOG_INF with printk and bracket led_start with
2a_pre_led_start / 2b_post_led_start. Also add 4a_pre_wdt /
4b_post_wdt to bracket watchdog_init since that's the next
candidate after the LED block.
---
diff --git a/omi/firmware/devkit/src/main.c b/omi/firmware/devkit/src/main.c
--- a/omi/firmware/devkit/src/main.c
+++ b/omi/firmware/devkit/src/main.c
@@ -163,9 +163,10 @@ int main(void)
      * SPI_NOR=n (deps unsatisfied in NCS v2.7). See patch header. */
     printk("WR_TRACE: 2_qspi_done\n");
     LOG_PRINTK("\n");
-    LOG_INF("Initializing LEDs...\n");
+    printk("WR_TRACE: 2a_pre_led_start\n");

     err = led_start();
+    printk("WR_TRACE: 2b_post_led_start err=%d\n", err);
     if (err) {
         LOG_ERR("Failed to initialize LEDs (err %d)", err);
         return err;
@@ -176,7 +177,9 @@ int main(void)
     printk("WR_TRACE: 4_post_led_seq\n");

     // Initialize watchdog early to catch any freezes during boot
+    printk("WR_TRACE: 4a_pre_wdt\n");
     err = watchdog_init();
+    printk("WR_TRACE: 4b_post_wdt err=%d\n", err);
     if (err) {
         LOG_WRN("Watchdog init failed (err %d), continuing without watchdog", err);
     }
