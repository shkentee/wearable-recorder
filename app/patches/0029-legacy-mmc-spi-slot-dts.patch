From: knsol <noreply@anthropic.com>
Subject: [PATCH] fix: switch DTS to legacy zephyr,mmc-spi-slot pattern

disk_access_init returns -22 (-EINVAL) immediately, meaning the SD
disk is never registered under the name 'SD'. The current DTS uses
zephyr,sdhc-spi-slot + zephyr,sdmmc-disk child (the new SDHC subsys
pattern), which apparently doesn't register a disk under the legacy
name.

omi's sdcard.c uses the legacy disk_access_init(name) API and
expects 'SD'. Rewrite the overlay to the legacy zephyr,mmc-spi-slot
pattern that the legacy DISK_DRIVER_SDMMC driver speaks directly.
---
diff --git a/omi/firmware/devkit/overlay/xiao_ble_sense_devkitv1-spisd.overlay b/omi/firmware/devkit/overlay/xiao_ble_sense_devkitv1-spisd.overlay
--- a/omi/firmware/devkit/overlay/xiao_ble_sense_devkitv1-spisd.overlay
+++ b/omi/firmware/devkit/overlay/xiao_ble_sense_devkitv1-spisd.overlay
@@ -3,16 +3,11 @@
     pinctrl-0 = <&custom_spi>;
     pinctrl-1 = <&custom_spi>;
     pinctrl-names = "default", "sleep";
-    cs-gpios = <&gpio1 13 GPIO_ACTIVE_LOW>;  // patch 0018: CS on D8 = P1.13 (was P0.28)
-    sdhc0: sdhc@0 {
-        compatible = "zephyr,sdhc-spi-slot";
+    cs-gpios = <&gpio1 13 GPIO_ACTIVE_LOW>;  // patch 0018/0029: CS on D8 = P1.13
+    sdcard: sdcard@0 {
+        compatible = "zephyr,mmc-spi-slot";
         reg = <0>;
         status = "okay";
-        label = "SDHC_0";
-        mmc {
-            compatible = "zephyr,sdmmc-disk";
-            status = "okay";
-            disk-name = "SD";
-        };
-        spi-max-frequency = <1000000>;  // patch 0017: lowered 24 MHz → 1 MHz for SD init reliability
+        spi-max-frequency = <1000000>;  // patch 0017: 1 MHz for SD init reliability
     };
 };
 &pinctrl {
